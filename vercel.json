{
    "experimentalServices": {
        "frontend": {
            "entrypoint": "frontend",
            "routePrefix": "/",
            "framework": "nextjs"
        },
        "backend": {
            "entrypoint": "backend/main.py",
            "routePrefix": "/_/backend"
        }
    },
    "functions": {
        "backend/main.py": {
            "maxDuration": 60,
            "memory": 1024,
            "runtime": "python3.12"
        }
    }
}
